            ROUND(MAX(temperature_exterieur)::NUMERIC, 2)   AS max_temp_exterior,
            ROUND(AVG(avg_indoor_air_quality)::NUMERIC, 0)  AS media_aire_ppm
        FROM home_sensor_readings;
